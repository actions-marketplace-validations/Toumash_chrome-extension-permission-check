{
  "name": "Test Extension Safe Update",
  "version": "1.1.0",
  "manifest_version": 3,
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": [
    "https://example.com/*",
    "https://*.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://example.com/*"],
      "js": ["content.js"]
    }
  ]
}
